" Sensible, plugin-free Vim defaults for fast terminal editing.

set nocompatible
filetype plugin indent on
syntax enable

set number
set relativenumber
set ruler
set showcmd
set showmode
set cursorline
set hidden
set mouse=a
set splitbelow
set splitright
set ignorecase
set smartcase
set incsearch
set hlsearch
set wildmenu
set wildmode=longest:full,full
set scrolloff=4
set sidescrolloff=8
set expandtab
set shiftwidth=4
set softtabstop=4
set tabstop=4
set smartindent
set autoindent
set backspace=indent,eol,start
set updatetime=300
set timeoutlen=500
set nobackup
set nowritebackup

if has('termguicolors')
  set termguicolors
endif

if has('clipboard')
  set clipboard+=unnamed
  if has('unnamedplus')
    set clipboard+=unnamedplus
  endif
endif

let s:vim_data = expand('~/.vim')
let &directory = s:vim_data . '/swap//'
let &undodir = s:vim_data . '/undo//'
let &backupdir = s:vim_data . '/backup//'
silent! call mkdir(&directory, 'p')
silent! call mkdir(&undodir, 'p')
silent! call mkdir(&backupdir, 'p')
if has('persistent_undo')
  set undofile
endif

if exists('g:colors_name')
  highlight clear SignColumn
endif

silent! colorscheme habamax

let mapleader = ' '
nnoremap <leader>w :write<CR>
nnoremap <leader>q :quit<CR>
nnoremap <leader>h :nohlsearch<CR>
